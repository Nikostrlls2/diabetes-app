{
  "name": "diabetes-app",
  "private": true,
  "version": "0.0.0",
  "description": "GlucoPilot helps people with type 1 diabetes track carbs, reminders, glucose notes, and educational AI support.",
  "author": "Clwzy",
  "type": "module",
  "main": "desktop-dist/electron/main.js",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "build:desktop-code": "tsc -p tsconfig.desktop.json",
    "desktop:start": "npm run build && npm run build:desktop-code && electron .",
    "android:local-properties": "node ./scripts/write-android-local-properties.mjs",
    "android:sync": "npm run android:local-properties && npx cap sync android",
    "android:prepare": "npm run build && npm run android:sync",
    "android:apk:release": "npm run android:prepare && node ./scripts/run-android-gradle.mjs assembleRelease",
    "android:aab:release": "npm run android:prepare && node ./scripts/run-android-gradle.mjs bundleRelease",
    "android:build:debug": "npm run android:prepare && node ./scripts/run-android-gradle.mjs assembleDebug",
    "android:open": "npx cap open android",
    "lint": "eslint .",
    "package:appx": "npm run build && npm run build:desktop-code && electron-builder --win appx",
    "package:win:nsis": "npm run build && npm run build:desktop-code && electron-builder --win nsis",
    "package:win:unpacked": "npm run build && npm run build:desktop-code && electron-builder --win dir",
    "package:win": "npm run build && npm run build:desktop-code && electron-builder --win portable",
    "preview": "vite preview",
    "server": "tsx server/index.ts"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "openai": "^6.32.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "png-to-ico": "^3.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "com.clwzy.glucopilot",
    "productName": "GlucoPilot",
    "compression": "store",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "desktop-dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "desktop-dist/electron/main.js"
    },
    "win": {
      "icon": "public/logo.ico",
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ],
      "artifactName": "GlucoPilot-${version}.${ext}"
    },
    "nsis": {
      "artifactName": "GlucoPilot-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "GlucoPilot-Portable-${version}.${ext}"
    },
    "appx": {
      "identityName": "Clwzy.GlucoPilot",
      "publisherDisplayName": "Clwzy",
      "displayName": "GlucoPilot",
      "applicationId": "GlucoPilot",
      "backgroundColor": "#f4efe6",
      "artifactName": "GlucoPilot-${version}.${ext}"
    },
    "toolsets": {
      "winCodeSign": "1.1.0"
    }
  }
}
